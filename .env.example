# Discord Configuration
# Required: Bot token from the Discord Developer Portal
DISCORD_TOKEN=
# Required: Application ID (Client ID) from the Discord Developer Portal
DISCORD_CLIENT_ID=
# Optional: Guild ID for instant command registration during development
DISCORD_GUILD_ID=
# Optional: Bot owner user ID for restricted commands
BOT_OWNER_ID=

# AI Provider Configuration
# Provider: "nvidia" | "ollama" | "openai" | "custom"
AI_PROVIDER=nvidia
# API key (required for NVIDIA, OpenAI, custom)
AI_API_KEY=
# Base URL (optional, defaults per provider)
AI_BASE_URL=
# Model name (optional, defaults per provider)
AI_MODEL=
# Request timeout in milliseconds (optional, default: 30000)
AI_TIMEOUT_MS=30000

# Storage Configuration
# Directory for local plan storage (optional, default: ./data)
STORAGE_DIR=./data

# Logging Configuration
# Level: "debug" | "info" | "warn" | "error" | "silent"
LOG_LEVEL=info

# Application
# Node environment
NODE_ENV=development
